<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/modelCard"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="2dp"
    app:strokeColor="@color/model_card_stroke"
    app:cardBackgroundColor="@color/model_card_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp"
        android:gravity="center">

        <!-- Model Icon -->
        <ImageView
            android:id="@+id/ivModelIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_auto_awesome"
            app:tint="?attr/colorOnSurfaceVariant" />

        <!-- Model Name -->
        <TextView
            android:id="@+id/tvModelName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GPT-4o mini"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="8dp" />

        <!-- Provider Badge -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipProvider"
            style="@style/Widget.Material3.Chip.Assist"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:text="OpenAI"
            android:textSize="10sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:chipMinHeight="24dp"
            app:chipStartPadding="6dp"
            app:chipEndPadding="6dp"
            app:chipIconTint="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>