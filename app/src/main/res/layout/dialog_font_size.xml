<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_top_rounded_background"
    android:padding="24dp">

    <!-- Font Size Title -->
    <TextView
        android:id="@+id/tvFontSizeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp"
        android:text="Font Size"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:textColor="?attr/colorOnSurface" />

    <!-- Font Size Control Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <!-- Small A Icon -->
        <TextView
            android:id="@+id/tvSmallA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginEnd="16dp"
            android:fontFamily="sans-serif-medium" />

        <!-- Font Size Slider -->
        <com.google.android.material.slider.Slider
            android:id="@+id/fontSizeSlider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:valueFrom="12"
            android:valueTo="24"
            android:value="16"
            android:stepSize="1"
            app:thumbColor="?attr/colorPrimary"
            app:trackColorActive="?attr/colorPrimary"
            app:trackColorInactive="?attr/colorOutlineVariant" />

        <!-- Large A Icon -->
        <TextView
            android:id="@+id/tvLargeA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A"
            android:textSize="24sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginStart="16dp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- Preview Text -->
    <TextView
        android:id="@+id/tvPreviewText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Preview: This is how your text will look"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"
        android:padding="16dp"
        android:background="@drawable/rounded_background"
        android:backgroundTint="?attr/colorSurfaceVariant" />

    <!-- Apply Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplyFontSize"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Apply" />

</LinearLayout>